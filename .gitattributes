# Normalize line endings
* text=auto eol=lf

# PHP
*.php text eol=lf

# Config / data
*.json text eol=lf
*.xml  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.lock text eol=lf

# Docs
*.md   text eol=lf

# Shell
*.sh text eol=lf

# Binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.tar  binary
*.gz   binary

# Exclude from composer dist (git archive / composer install --prefer-dist)
/.claude/          export-ignore
/.github/          export-ignore
/tests/            export-ignore
/docs/             export-ignore
CLAUDE.md          export-ignore
phpunit.xml        export-ignore
.gitattributes     export-ignore
.gitignore         export-ignore
