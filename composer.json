{
    "name": "thewildfields/tavriia",
    "description": "A reusable PHP framework providing a clean, typed, PSR-compliant OOP abstraction layer over WordPress core functions.",
    "type": "library",
    "license": "MIT",
    "keywords": ["wordpress", "framework", "plugin", "wp", "abstraction"],
    "authors": [
        {
            "name": "The Wild Fields",
            "homepage": "https://thewildfields.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "suggest": {
        "ext-json": "Required by WordPress core and needed for HTTP response handling"
    },
    "require-dev": {
        "brain/monkey": "^2",
        "mockery/mockery": "^1",
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "TheWildFields\\Tavriia\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TheWildFields\\Tavriia\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": false
}
